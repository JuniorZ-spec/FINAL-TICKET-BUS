{
  "name": "ticket-bus",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:client": "cd client && npx eslint src --ext .js,.jsx",
    "lint:backend": "cd backend && npx eslint . --ext .js",
    "format:client": "cd client && npx prettier --write src",
    "format:backend": "cd backend && npx prettier --write ."
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.1",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "client/src/**/*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
