# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ticketbus?schema=public"

# Redis (local: redis://localhost:6379 | cloud: redis://default:XXX@host:6379)
REDIS_URL="redis://localhost:6379"

# JWT
jwt_secret="your_jwt_secret_here"

# Email (Gmail app password)
EMAIL="your_email@gmail.com"
EMAIL_PASS="your_gmail_app_password"

# Frontend URL (pour les liens de reset password)
FRONTEND_URL="http://localhost:5173"

# Admin initial (utilisé par scripts/seedAdmin.js)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeThisPassword123!"

# Port du serveur (optionnel, défaut 5000)
PORT=5000
